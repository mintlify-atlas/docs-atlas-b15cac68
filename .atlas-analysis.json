  "keyFeatures": [
    "Multi-location employee management across branches (sedes)",
    "Real-time attendance tracking with geolocation support",
    "Role-based access control (RBAC) with granular module permissions",
    "Vacation management with balance tracking and bulk Excel upload",
    "Organizational hierarchy management with supervisor assignments",
    "AI-powered monthly reports for authorized administrators",
    "Mobile access configuration for field employees",
    "Leave requests with calendar view and approval workflow",
    "Reports center with Excel export for employees, attendance, vacations, and terminations",
    "Supabase-powered backend with Row Level Security (RLS)"
  ],
  "publicApiSurface": [
    "GET /employees — List employees with role-scoped filtering",
    "POST /register-employee — Create new employee record",
    "GET /attendance-list — View attendance records with pagination",
    "GET /requests — View pending leave/absence requests",
    "GET /calendar — Calendar view of approved requests",
    "GET /vacaciones — Vacation dashboard with balance overview",
    "GET /reports — Reports center for data export",
    "GET /roles — Role management and module permissions",
    "GET /positions — Job positions configuration",
    "GET /areas — Organizational areas management",
    "GET /schedules — Work schedules management",
    "GET /hierarchy-management — Supervisor hierarchy configuration",
    "GET /organization-structure — Organization structure management",
    "GET /mobile-access-config — Mobile app access configuration",
    "supabase.rpc('get_employees_by_user_area') — Fetch employees by user's area scope",
    "supabase.rpc('get_dashboard_stats') — Fetch dashboard statistics",
    "supabase.rpc('get_dashboard_stats_local_boss') — Dashboard stats for local managers"
  ]
